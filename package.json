{
  "name": "guarani-myths",
  "version": "1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.x"
  },
  "packageManager": "npm@12.1.0",
  "scripts": {
    "dev": "npm run dev:client",
    "build": "npm run build:client",
    "dev:client": "rsbuild dev --root client",
    "build:client": "rsbuild build --root client --environment web",
    "preview:client": "rsbuild preview --root client",
    "lint:client": "biome check client/",
    "lint:fix:client": "biome check --write --unsafe client/",
    "format:client": "biome format --write client/src/",
    "format:server": "biome format --write server/",
    "format": "npm run format:client && npm run format:server"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/mongodb": "^10.0.0",
    "@fastify/oauth2": "^8.2.0",
    "@headlessui/react": "^2.2.10",
    "@mdx-js/react": "^3.1.1",
    "@unkey/api": "^2.4.0",
    "clsx": "^2.1.1",
    "darkify-js": "^1.1.13",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "lucide-react": "^1.23.0",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@rsbuild/core": "^2.1.4",
    "@rsbuild/plugin-mdx": "^1.1.3",
    "@rsbuild/plugin-react": "2.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "tailwindcss": "^4.3.2"
  }
}
