{
  "name": "guarani-myths",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "npm run dev:client",
    "build": "npm run build:client",
    "dev:client": "cd client && rsbuild dev",
    "build:client": "cd client && rsbuild build --environment web",
    "preview:client": "cd client && rsbuild preview",
    "lint:client": "cd client && biome check",
    "lint:fix:client": "cd client && biome check --write --unsafe",
    "format:client": "cd client && biome format ./src/ --write",
    "format:server": "cd server && biome format . --write",
    "format": "npm run format:client && npm run format:server"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/mongodb": "^10.0.0",
    "@fastify/oauth2": "^8.2.0",
    "@headlessui/react": "^2.2.10",
    "@mdx-js/react": "^3.1.1",
    "@unkey/api": "^2.4.0",
    "clsx": "^2.1.1",
    "darkify-js": "^1.1.13",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@rsbuild/core": "^2.0.15",
    "@rsbuild/plugin-mdx": "^1.1.3",
    "@rsbuild/plugin-react": "2.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.15",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "tailwindcss": "^4.3.1"
  }
}
